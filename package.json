{
  "name": "substance-sampler",
  "version": "0.1.0",
  "description": "Browser-based photo-to-PBR texture creation for indie game and 3D artists, powered by WebGPU and WASM.",
  "type": "module",
  "private": false,
  "homepage": "https://baditaflorin.github.io/substance-sampler/",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/clean-pages.mjs",
    "build": "tsc -b && vite build && node scripts/build-info.mjs docs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:realdata": "bash scripts/realdata.sh",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check . && tsc -b --pretty false",
    "fmt": "prettier --write .",
    "smoke": "bash scripts/smoke.sh",
    "screenshot": "node scripts/capture-screenshot.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.16",
    "comlink": "^4.4.2",
    "fflate": "^0.8.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
