#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file required}"
first_line="$(sed -n '1p' "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data|security|perf)(\([a-zA-Z0-9_-]+\))?!?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits, e.g. feat: add texture export"
  exit 1
fi
